{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Locality",
  "description": "Locality mounts apps like Notion and Google Docs as local files for humans, editors, and agents.",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#0F766E"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/codeflash-ai/locality",
        "icon": "github"
      },
      {
        "label": "Releases",
        "href": "https://github.com/codeflash-ai/locality/releases",
        "icon": "download"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install Locality",
      "href": "/install"
    }
  },
  "contextual": {
    "options": ["copy"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "icon": "rocket",
        "pages": [
          "overview",
          "install",
          "quickstart",
          "filesystem-model"
        ]
      },
      {
        "group": "Use Locality",
        "icon": "folder-sync",
        "pages": [
          "desktop",
          "agents",
          "best-practices",
          "sync-safety",
          "use-cases"
        ]
      },
      {
        "group": "Reference",
        "icon": "terminal",
        "pages": [
          "cli-reference",
          "connectors/notion",
          "connectors/google-docs",
          "okf-export"
        ]
      },
      {
        "group": "Operations",
        "icon": "settings",
        "pages": [
          "troubleshooting",
          "development"
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/docs/:path*",
      "destination": "/:path*"
    }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/codeflash-ai/locality"
    },
    "links": [
      {
        "label": "Product",
        "items": [
          {
            "label": "Install",
            "href": "/install"
          },
          {
            "label": "GitHub Releases",
            "href": "https://github.com/codeflash-ai/locality/releases"
          }
        ]
      }
    ]
  }
}
