{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AFS",
  "version": "0.1.0",
  "identifier": "ai.codeflash.afs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "./scripts/prepare-macos-file-provider.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "AFS",
        "width": 960,
        "height": 680,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Mount workspaces as local files for agents.",
    "longDescription": "AFS lets agents edit connected workspaces through local files while keeping remote writes reviewable.",
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-",
      "files": {
        "PlugIns/AgentFSFileProvider.appex": "macos/AgentFSFileProvider/AgentFSFileProvider.appex",
        "MacOS/agentfs-file-providerctl": "macos/AgentFSFileProvider/agentfs-file-providerctl",
        "MacOS/afsd": "macos/afsd"
      },
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    }
  }
}
