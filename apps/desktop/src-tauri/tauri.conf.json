{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locality",
  "version": "0.1.4",
  "identifier": "ai.codeflash.locality",
  "build": {
    "beforeDevCommand": "node ./scripts/dev-command.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node ./scripts/prepare-bundle.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Locality",
        "width": 960,
        "height": 680,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Mount workspaces as local files for agents.",
    "longDescription": "Locality lets agents edit connected workspaces through local files while keeping remote writes reviewable.",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-",
      "files": {
        "PlugIns/LocalityFileProvider.appex": "macos/LocalityFileProvider/LocalityFileProvider.appex",
        "MacOS/locality-file-providerctl": "macos/LocalityFileProvider/locality-file-providerctl",
        "MacOS/loc": "macos/loc",
        "MacOS/localityd": "macos/localityd"
      },
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    },
    "linux": {
      "deb": {
        "depends": ["fuse3", "systemd"],
        "preRemoveScript": "linux/preremove.sh",
        "files": {
          "/usr/bin/loc": "linux/loc",
          "/usr/bin/localityd": "linux/localityd",
          "/usr/bin/locality-fuse": "linux/locality-fuse"
        }
      },
      "rpm": {
        "depends": ["fuse3", "systemd"],
        "preRemoveScript": "linux/preremove.sh",
        "files": {
          "/usr/bin/loc": "linux/loc",
          "/usr/bin/localityd": "linux/localityd",
          "/usr/bin/locality-fuse": "linux/locality-fuse"
        }
      }
    }
  }
}
